{
  "name": "csound-ide-tests",
  "version": "1.0.0",
  "description": "Puppeteer test suite for ide.csound.com",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "node tests/runner.js",
    "test:page-load": "node tests/01-page-load.js",
    "test:editor": "node tests/02-editor.js",
    "test:playback": "node tests/03-playback.js",
    "test:all": "node tests/runner.js",
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@puppeteer/browsers": "^2.13.0",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.40.0",
    "puppeteer-core": "^24.40.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
