# ──────────────────────────────────────────────────
# Csound IDE — Puppeteer Test Suite
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ──────────────────────────────────────────────────

# ── Target URLs ──────────────────────────────────
# Base URL of the Csound IDE (landing page).
IDE_BASE_URL=https://ide.csound.com

# Full URL to an editable project (used by editor, playback, and file-mgmt suites).
IDE_PROJECT_URL=https://ide.csound.com/editor/jQiIAlDXxe4KEPDTllii

# ── Browser ──────────────────────────────────────
# Path to a Chrome/Chromium binary. Leave blank to auto-detect.
# PUPPETEER_EXECUTABLE_PATH=

# Set to "false" to launch a visible browser window (useful for debugging).
# HEADLESS=true